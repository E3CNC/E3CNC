#!/usr/bin/env bash
# e3cnc-tui — architecture-aware wrapper
#
# Detects the host CPU architecture and runs the correct binary.
# Supports: arm64 (aarch64), amd64 (x86_64)
set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
ARCH="$(uname -m)"

case "$ARCH" in
    aarch64|arm64)
        exec "$DIR/e3cnc-tui-arm64" "$@"
        ;;
    x86_64|amd64)
        exec "$DIR/e3cnc-tui-amd64" "$@"
        ;;
    *)
        echo "Unsupported architecture: $ARCH" >&2
        echo "Supported: aarch64/arm64, x86_64/amd64" >&2
        exit 1
        ;;
esac
