# Dockerfile.multi-instance
# Simulates a machine with two Klipper/Moonraker instances
# to test the CLI's multi-instance detection (detect_instances()).
#
# Build:
#   docker build -t e3cnc-multi -f tests/Dockerfile.multi-instance .
#
# Test instance detection:
#   docker run --rm e3cnc-multi bash -c 'cd ~/E3CNC && export PATH="$HOME/.local/bin:$PATH" && echo y | ./e3cnc-cli install'
#
# Test instance switching:
#   docker run --rm -it e3cnc-multi bash -c 'cd ~/E3CNC && export PATH="$HOME/.local/bin:$PATH" && ./e3cnc-cli'
#
# Test --instance flag:
#   docker run --rm e3cnc-multi bash -c 'cd ~/E3CNC && export PATH="$HOME/.local/bin:$PATH" && ./e3cnc-cli status --instance test2'

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# Install bare minimum
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    python3 \
    sudo \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash testbed && echo "testbed ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER testbed
WORKDIR /home/testbed

# Copy the current working tree into the container
COPY --chown=testbed:testbed . /home/testbed/E3CNC

# Shared Klipper + Moonraker source trees, shared frontend
RUN mkdir -p /home/testbed/moonraker/moonraker/components \
             /home/testbed/klipper/klippy/extras \
             /home/testbed/mainsail

# ── Create Instance 1 (KIAUH-style test1) ────────────────────────────────
RUN mkdir -p /home/testbed/printer_test1_data/config/E3CNC/macros \
             /home/testbed/printer_test1_data/scripts \
             /home/testbed/printer_test1_data/logs \
             /home/testbed/printer_test1_data/systemd \
    && printf '[server]\nport: 7125\n' > /home/testbed/printer_test1_data/config/moonraker.conf \
    && touch /home/testbed/printer_test1_data/config/printer.cfg \
    && printf 'MOONRAKER_ARGS="/home/testbed/moonraker/moonraker/moonraker.py -d /home/testbed/printer_test1_data"\n' > /home/testbed/printer_test1_data/systemd/moonraker.env \
    && printf 'KLIPPER_ARGS="/home/testbed/klipper/klippy/klippy.py /home/testbed/printer_test1_data/config/printer.cfg -I /home/testbed/printer_test1_data/comms/klippy.serial -l /home/testbed/printer_test1_data/logs/klippy.log -a /home/testbed/printer_test1_data/comms/klippy.sock"\n' > /home/testbed/printer_test1_data/systemd/klipper.env \
    && printf 'test1\n' > /home/testbed/printer_test1_data/moonraker.asvc

# ── Create Instance 2 (KIAUH-style test2) ────────────────────────────────
RUN mkdir -p /home/testbed/printer_test2_data/config/E3CNC/macros \
             /home/testbed/printer_test2_data/scripts \
             /home/testbed/printer_test2_data/logs \
             /home/testbed/printer_test2_data/systemd \
    && printf '[server]\nport: 7126\n' > /home/testbed/printer_test2_data/config/moonraker.conf \
    && touch /home/testbed/printer_test2_data/config/printer.cfg \
    && printf 'MOONRAKER_ARGS="/home/testbed/moonraker/moonraker/moonraker.py -d /home/testbed/printer_test2_data"\n' > /home/testbed/printer_test2_data/systemd/moonraker.env \
    && printf 'KLIPPER_ARGS="/home/testbed/klipper/klippy/klippy.py /home/testbed/printer_test2_data/config/printer.cfg -I /home/testbed/printer_test2_data/comms/klippy.serial -l /home/testbed/printer_test2_data/logs/klippy.log -a /home/testbed/printer_test2_data/comms/klippy.sock"\n' > /home/testbed/printer_test2_data/systemd/klipper.env \
    && printf 'test2\n' > /home/testbed/printer_test2_data/moonraker.asvc

CMD ["bash"]
