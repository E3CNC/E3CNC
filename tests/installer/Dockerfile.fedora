# syntax=docker/dockerfile:1
# E3CNC Installer Test - Fedora 38 (dnf)
FROM --platform=linux/amd64 fedora:38

ARG DEBIAN_FRONTEND=noninteractive

# Install system dependencies (dnf equivalents)
RUN dnf install -y \
    git \
    curl \
    unzip \
    zstd \
    supervisor \
    python3-pip \
    iproute \
    coreutils \
    sudo \
    jq \
    procps-ng \
    net-tools \
    && dnf clean all

# Create a non-root user for sudo tests
RUN useradd -m -s /bin/bash testuser && \
    echo "testuser:testpass" | chpasswd && \
    echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Copy mock binary and install script
COPY tests/installer/mock-binary/e3cnc-tui /usr/local/bin/e3cnc-tui
COPY tests/installer/mock-binary/e3cnc-tui /tmp/e3cnc-tui
RUN chmod +x /usr/local/bin/e3cnc-tui /tmp/e3cnc-tui

WORKDIR /workspace

# Copy the install script and test scripts
COPY install.sh /workspace/install.sh
COPY tests/installer/test-runner.sh /workspace/test-runner.sh
COPY tests/installer/test-install.sh /workspace/test-install.sh
RUN chmod +x /workspace/install.sh /workspace/test-runner.sh /workspace/test-install.sh

SHELL ["/bin/bash", "-c"]

CMD ["/bin/bash"]
