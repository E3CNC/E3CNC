# Dockerfile.fresh-install
# Simulates a clean Linux machine to test e3cnc-cli install.
#
# Build:
#   docker build -t e3cnc-test -f tests/Dockerfile.fresh-install .
#
# Run (interactive):
#   docker run -it --rm e3cnc-test
#
# Run (auto-check deps):
#   docker run --rm e3cnc-test bash -c 'cd ~/E3CNC && ./e3cnc-cli check'
#
# Run (full install bootstrap MVP):
#   docker run --rm e3cnc-test bash -c 'cd ~/E3CNC && echo y | ./e3cnc-cli install'

FROM ubuntu:24.04

# Prevent tzdata interactive prompt
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# Install bare minimum — NO ansible, NO bun, NO nvm
# python3-pip and python3-venv are needed by the bootstrap-stack role
# to create virtualenvs and pip-install Python deps (Klipper, Moonraker)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    python3 \
    python3-pip \
    python3-venv \
    sudo \
    ca-certificates \
    socat \
    libsodium23 \
    avahi-utils \
    && rm -rf /var/lib/apt/lists/*

# Create a non-root user for testing (e3cnc-cli installs user-level tools)
RUN useradd -m -s /bin/bash testbed && echo "testbed ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER testbed
WORKDIR /home/testbed

# Copy the current working tree into the container
COPY --chown=testbed:testbed . /home/testbed/E3CNC

CMD ["bash"]
