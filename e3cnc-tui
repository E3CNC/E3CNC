#!/usr/bin/env python3
"""
e3cnc-tui — Terminal User Interface for E3CNC UI management.

Zero dependencies — uses only Python stdlib.

Arrow keys to navigate, Enter to run, q to quit.
Output prints inline in the same terminal.
"""

import os
import sys
import termios
import tty

from _e3cnc_shared import (
    VERSION, TOOL_NAME,
    check_dependencies, check_status,
    run_backup, run_diagnose, run_logs,
    run_ansible_playbook,
    INSTALL_PLAYBOOK, DEPLOY_PLAYBOOK, UNINSTALL_PLAYBOOK, REDEPLOY_PLAYBOOK,
    print_banner,
)

# ── Menu data ──────────────────────────────────────────────────────────────

ITEMS = [
    ("[S] Status",      "status"),
    ("[I] Install",     "install"),
    ("[D] Deploy",      "deploy"),
    ("[U] Update",      "update"),
    ("[X] Uninstall",   "uninstall"),
    ("[C] Check Deps",  "check"),
    ("[B] Backup",      "backup"),
    ("[R] Restore",     "restore"),
    ("[G] Diagnose",    "diagnose"),
    ("[L] Logs",        "logs"),
    ("",                None),       # spacer
    ("[Q] Quit",        "quit"),
]

LABELS = {
    "status": "Status Check", "install": "Install",
    "deploy": "Deploy", "update": "Update",
    "uninstall": "Uninstall", "check": "Dependency Check",
    "backup": "Backup", "restore": "Restore",
    "diagnose": "Diagnostics", "logs": "Logs",
}

BANNER = """\
\x1b[32m\
███████╗ ██████╗   ██████╗ ███╗   ██╗  ██████╗
██╔════╝ ╚════██╗ ██╔════╝ ████╗  ██║ ██╔════╝
█████╗    █████╔╝ ██║      ██╔██╗ ██║ ██║
██╔══╝    ╚═══██╗ ██║      ██║╚██╗██║ ██║
███████╗ ██████╔╝ ╚██████╗ ██║ ╚████║ ╚██████╗
╚══════╝ ╚═════╝   ╚═════╝ ╚═╝  ╚═══╝  ╚═════╝\
\x1b[0m"""


# ── Key reader ─────────────────────────────────────────────────────────────

def _getch() -> str:
    """Read a single keypress without Enter."""
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        ch = sys.stdin.read(1)
        if ch == "\x1b":
            seq = ch + sys.stdin.read(2)
            return seq
        return ch
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


# ── Menu renderer ──────────────────────────────────────────────────────────

def _clear() -> None:
    """Clear screen and move cursor home."""
    sys.stdout.write("\x1b[2J\x1b[H")
    sys.stdout.flush()


def _render(selected: int) -> None:
    """Render the menu at the current cursor position."""
    lines = []
    lines.append(BANNER)
    lines.append(f"")
    lines.append(f"  \x1b[90m{TOOL_NAME} v{VERSION}  —  Terminal UI\x1b[0m")
    lines.append(f"")

    for i, (label, cmd) in enumerate(ITEMS):
        prefix = "  "
        if cmd is None:
            lines.append("")
            continue
        if i == selected:
            lines.append(f"  \x1b[42m\x1b[30m{label}\x1b[0m")
        else:
            lines.append(f"  {label}")

    lines.append(f"")
    lines.append(f"  \x1b[90m↑↓ navigate · Enter run · q quit\x1b[0m")

    # Write from top of screen
    sys.stdout.write("\x1b[H" + "\n".join(lines))
    sys.stdout.flush()


# ── Command runner ─────────────────────────────────────────────────────────

def _run_command(cmd: str) -> None:
    """Run a command, printing output inline."""
    label = LABELS.get(cmd, cmd)

    # Exit alternate screen / clear the TUI
    sys.stdout.write("\x1b[?1049l\x1b[2J\x1b[H")
    sys.stdout.flush()

    print()
    print_banner()
    print(f"\n  \x1b[36m>> Running {label}...\x1b[0m\n")

    if cmd == "status":
        _, _, lines = check_status()
        for line in lines:
            print(line)
    elif cmd == "check":
        _, lines = check_dependencies()
        for line in lines:
            print(line)
    elif cmd == "backup":
        result = run_backup(None)
        print(result.output)
    elif cmd == "diagnose":
        result = run_diagnose(None)
        print(result.output)
    elif cmd == "logs":
        result = run_logs(None, 20)
        print(result.output)
    elif cmd == "restore":
        print("  \x1b[33mUse: e3cnc-cli restore <backup-dir>\x1b[0m")
    elif cmd in ("install", "deploy", "update", "uninstall"):
        playbook = {
            "install": INSTALL_PLAYBOOK,
            "deploy": DEPLOY_PLAYBOOK,
            "update": REDEPLOY_PLAYBOOK,
            "uninstall": UNINSTALL_PLAYBOOK,
        }[cmd]
        result = run_ansible_playbook(playbook, None, False, False, label)
        icon = "✓" if result.success else "✗"
        print(f"\n  \x1b[{'32' if result.success else '31'}m{icon} {label} completed\x1b[0m")

    print()
    input("  \x1b[90mPress Enter to return to menu...\x1b[0m")


# ── Main loop ──────────────────────────────────────────────────────────────

def main() -> None:
    selected = 0

    # Enter alternate screen
    sys.stdout.write("\x1b[?1049h")
    _clear()

    try:
        while True:
            _render(selected)
            key = _getch()

            if key == "\x1b[A":  # Up
                selected = (selected - 1) % len(ITEMS)
                while ITEMS[selected][1] is None:  # skip spacers
                    selected = (selected - 1) % len(ITEMS)
            elif key == "\x1b[B":  # Down
                selected = (selected + 1) % len(ITEMS)
                while ITEMS[selected][1] is None:  # skip spacers
                    selected = (selected + 1) % len(ITEMS)
            elif key in ("\r", "\n"):  # Enter
                _, cmd = ITEMS[selected]
                if cmd is None:
                    continue
                if cmd == "quit":
                    break

                # Exit alternate screen before running command
                sys.stdout.write("\x1b[?1049l")
                sys.stdout.flush()

                _run_command(cmd)

                # Re-enter alternate screen
                sys.stdout.write("\x1b[?1049h")
                _clear()

            elif key == "q":
                break

    finally:
        sys.stdout.write("\x1b[?1049l\x1b[2J\x1b[H")
        sys.stdout.flush()


if __name__ == "__main__":
    main()
