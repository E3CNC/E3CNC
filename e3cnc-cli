#!/usr/bin/env python3
"""e3cnc-cli — Unified CLI for installing, deploying, and managing E3CNC UI.

Delegates to the cli/ package. Run with --help for full command list.
"""
import sys
import os

# Ensure the repo root is on sys.path so cli/ and _e3cnc_shared imports work
_THIS_DIR = os.path.dirname(os.path.abspath(__file__))
if _THIS_DIR not in sys.path:
    sys.path.insert(0, _THIS_DIR)

from cli import main

if __name__ == "__main__":
    main()
